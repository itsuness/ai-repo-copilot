# ── Required ────────────────────────────────────────────────
# GitHub personal access token — needs repo + pull_request scopes
GITHUB_TOKEN=ghp_your_token_here

# OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Gemini API key — get one at https://developers.generativeai.google.dev/console
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API key — get one at https://groq.com/console
GROQ_API_KEY=your_groq_api_key_here

# ── Optional ─────────────────────────────────────────────────
# Default repo so you can omit --repo on every command
# Format: owner/name
DEFAULT_REPO=

# Model to use — any OpenRouter model ID (default: anthropic/claude-sonnet-4-5)
# See https://openrouter.ai/models for available models
DEFAULT_MODEL=anthropic/claude-sonnet-4-5

# Log level: debug | info | warn | error | silent (default: info)
LOG_LEVEL=info